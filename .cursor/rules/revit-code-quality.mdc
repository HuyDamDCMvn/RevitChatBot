| RecipeStore | SkillKnowledgeRecipeStore | RegisterDynamicCode() |
| SkillKnowledgeIndex | SkillKnowledgeIndex | RegisterDynamicCode() |
| CompositeEngine | CompositeSkillEngine | InitializeSelfTraining() |
| PersistenceManager | SelfLearningPersistenceManager | InitializeSelfTraining() |
